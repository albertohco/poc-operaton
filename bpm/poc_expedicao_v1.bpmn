  <bpmn:process id="processo_expedicao_v1" name="Processo de Expedição Inteligente" isExecutable="true" camunda:versionTag="1.0" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1" name="Iniciar Expedição">
      <bpmn:outgoing>Flow_0f4sdke</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Separacao" name="Separar Pedido" camunda:formKey="form_separacao" camunda:candidateGroups="EXPEDICAO">
      <bpmn:incoming>Flow_0f4sdke</bpmn:incoming>
      <bpmn:incoming>Flow_1taggxr</bpmn:incoming>
      <bpmn:outgoing>Flow_05uuult</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Aprovado" name="Peso Validado?" default="Flow_01aym7u">
      <bpmn:incoming>Flow_1ctb2pq</bpmn:incoming>
      <bpmn:outgoing>Flow_01aym7u</bpmn:outgoing>
      <bpmn:outgoing>Flow_0mx5lh0</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Correcao" name="Corrigir Divergência de Peso" camunda:formKey="form_correcao" camunda:candidateGroups="EXPEDICAO">
      <bpmn:incoming>Flow_0mx5lh0</bpmn:incoming>
      <bpmn:outgoing>Flow_1taggxr</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Faturamento" name="Faturar Pedido" camunda:formKey="form_faturamento" camunda:candidateGroups="FINANCEIRO">
      <bpmn:incoming>Flow_01aym7u</bpmn:incoming>
      <bpmn:outgoing>Flow_0l1yxsm</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Coleta" name="Conferir e Coletar" camunda:formKey="form_coleta" camunda:candidateGroups="GATE">
      <bpmn:incoming>Flow_0l1yxsm</bpmn:incoming>
      <bpmn:outgoing>Flow_1d2mt9z</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0f4sdke" sourceRef="StartEvent_1" targetRef="Task_Separacao" />
    <bpmn:sequenceFlow id="Flow_05uuult" sourceRef="Task_Separacao" targetRef="Task_Validar" />
    <bpmn:sequenceFlow id="Flow_1ctb2pq" sourceRef="Task_Validar" targetRef="Gateway_Aprovado" />
    <bpmn:sequenceFlow id="Flow_01aym7u" name="Aprovado" sourceRef="Gateway_Aprovado" targetRef="Task_Faturamento" />
    <bpmn:sequenceFlow id="Flow_0mx5lh0" name="Reprovado" sourceRef="Gateway_Aprovado" targetRef="Task_Correcao">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${divergenciaPeso == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0l1yxsm" sourceRef="Task_Faturamento" targetRef="Task_Coleta" />
    <bpmn:endEvent id="EndEvent_1" name="Terminar Expedição">
      <bpmn:incoming>Flow_1d2mt9z</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1d2mt9z" sourceRef="Task_Coleta" targetRef="EndEvent_1" />
    <bpmn:sequenceFlow id="Flow_1taggxr" sourceRef="Task_Correcao" targetRef="Task_Separacao" />
    <bpmn:businessRuleTask id="Task_Validar" name="Validar Peso" camunda:resultVariable="divergenciaPeso" camunda:decisionRef="regras_decisao" camunda:decisionRefBinding="deployment" camunda:mapDecisionResult="singleEntry">
      <bpmn:incoming>Flow_05uuult</bpmn:incoming>
      <bpmn:outgoing>Flow_1ctb2pq</bpmn:outgoing>
    </bpmn:businessRuleTask>
  </bpmn:process>
